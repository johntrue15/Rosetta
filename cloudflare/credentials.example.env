# Copy to credentials.env in this directory (gitignored).
#
#   copy credentials.example.env credentials.env   # Windows PowerShell, from cloudflare/
#   cp credentials.example.env credentials.env     # macOS/Linux
#
# Create a Cloudflare API token at:
#   https://dash.cloudflare.com/profile/api-tokens
# Template: "Edit Cloudflare Workers" (or custom with Account + Workers Scripts edit)
#
# Account ID: Cloudflare dashboard → Workers & Pages → right sidebar, or Overview URL

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
